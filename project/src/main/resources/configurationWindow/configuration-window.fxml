<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="agh.ics.oop.simulationGUI.ConfigurationWindowPresenter"
            stylesheets="@configuration-window.css"
            styleClass="main-window"
            prefWidth="600" prefHeight="700">

    <top>
        <StackPane styleClass="header-bar">
            <Label text="Simulation Configuration" styleClass="window-title"/>
        </StackPane>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="20" styleClass="content-container">

                <VBox styleClass="config-card">
                    <Label text="Animal Genetics &amp; Behavior" styleClass="section-header"/>
                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="60"/>
                            <ColumnConstraints percentWidth="40"/>
                        </columnConstraints>

                        <Label text="Start Population:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Spinner fx:id="initialAnimalCountSpinner" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Initial Energy:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Spinner fx:id="initialEnergySpinner" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Max Energy Cap:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Spinner fx:id="maxEnergySpinner" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Energy to Reproduce:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Spinner fx:id="energyToReproduceSpinner" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Energy to Move:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Spinner fx:id="energyConsumedByMoveSpinner" GridPane.rowIndex="4" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Genotype Length:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Spinner fx:id="genotypeLengthSpinner" GridPane.rowIndex="5" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Min Mutations:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <Spinner fx:id="minMutationsSpinner" GridPane.rowIndex="6" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Max Mutations:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                        <Spinner fx:id="maxMutationsSpinner" GridPane.rowIndex="7" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="config-card">
                    <Label text="Map &amp; Environment" styleClass="section-header"/>
                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="60"/>
                            <ColumnConstraints percentWidth="40"/>
                        </columnConstraints>

                        <Label text="Map Width:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Spinner fx:id="widthSpinner" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Map Height:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Spinner fx:id="heightSpinner" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Map Variant:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ChoiceBox fx:id="mapTypeChoiceBox" GridPane.rowIndex="2" GridPane.columnIndex="1"
                                   maxWidth="Infinity"/>

                        <Label text="Start Plants:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Spinner fx:id="startPlantNumberSpinner" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Daily New Plants:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Spinner fx:id="dailyPlantNumberSpinner" GridPane.rowIndex="4" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Plant Energy Value:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Spinner fx:id="energyGainedByEatingSpinner" GridPane.rowIndex="5" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Separator GridPane.rowIndex="6" GridPane.columnSpan="2" styleClass="small-separator"/>

                        <Label text="Pheromone Decay (Days):" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                        <Spinner fx:id="daysToDecreaseFeromonSpinner" GridPane.rowIndex="7" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Smell Range:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                        <Spinner fx:id="smellRangeSpinner" GridPane.rowIndex="8" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Move to Pheromone Chance:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                        <Spinner fx:id="moveToFeromonProbabilitySpinner" GridPane.rowIndex="9" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="config-card">
                    <Label text="System Settings" styleClass="section-header"/>
                    <GridPane hgap="15" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="60"/>
                            <ColumnConstraints percentWidth="40"/>
                        </columnConstraints>

                        <Label text="Animation Delay (ms):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Spinner fx:id="moveDelaySpinner" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                 maxWidth="Infinity"/>

                        <Label text="Export Stats to CSV:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <CheckBox fx:id="saveToCSVCheckBox" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Enable Debug Logs:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <CheckBox fx:id="debugModeCheckBox" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="footer-bar">
            <Button fx:id="saveConfigurationButton" text="Save Preset" onAction="#handleSaveConfiguration"
                    styleClass="secondary-button"/>
            <Button fx:id="startSimulationButton" text="Start Simulation" onAction="#handleStartSimulation"
                    styleClass="primary-button"/>
            <Button fx:id="closeButton" text="Cancel" onAction="#handleClose" styleClass="danger-button"/>
        </HBox>
    </bottom>

</BorderPane>