<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="agh.ics.oop.simulationGUI.StartWindowPresenter"
            stylesheets="@start-window.css"
            styleClass="main-window"
            prefWidth="450" prefHeight="550">

    <center>
        <VBox spacing="25"
              alignment="CENTER"
              styleClass="content-container">

            <Label text="Darwin World Simulation"
                   styleClass="title-label"/>

            <Button text="Start New Simulation"
                    fx:id="startButton"
                    styleClass="menu-button"
                    onAction="#handleStartSimulation"/>

            <Button text="Load Config from JSON"
                    fx:id="loadFromJSON"
                    styleClass="menu-button"
                    onAction="#handleLoadFromJson"/>

            <Button text="Exit Game"
                    fx:id="closeButton"
                    styleClass="menu-button"
                    onAction="#handleClose"/>
        </VBox>
    </center>

</BorderPane>