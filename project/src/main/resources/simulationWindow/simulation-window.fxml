<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>

<BorderPane minWidth="1024.0" minHeight="600.0"
            prefWidth="1280.0" prefHeight="720.0"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="agh.ics.oop.simulationGUI.SimulationWindowPresenter"
            stylesheets="@simulation-window.css"
            styleClass="main-window">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-bar">
            <Button onAction="#onStartClicked" text="▶ Resume" styleClass="action-button, resume-button"/>
            <Button onAction="#onPauseClicked" text="⏸ Pause" styleClass="action-button, pause-button"/>

            <Separator orientation="VERTICAL"/>

            <ToggleButton fx:id="preferredFieldsToggle" onAction="#onShowPreferredFieldsClicked"
                          text="Show Jungle Tiles" styleClass="toggle-btn"/>
            <ToggleButton fx:id="dominantGenotypeToggle" onAction="#onShowDominantGenotypeClicked"
                          text="Highlight Dominant Genotype" styleClass="toggle-btn"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" styleClass="sidebar">
            <Label styleClass="section-title" text="Tracked Animal"/>

            <Label fx:id="trackedAnimalStatusLabel" text="(Click animal to track)" styleClass="status-label"/>

            <Button fx:id="stopTrackingButton" text="Stop Tracking"
                    onAction="#onStopTrackingClicked" disable="true"
                    maxWidth="Infinity" styleClass="stop-button"/>

            <Separator styleClass="sidebar-separator"/>

            <VBox spacing="5" styleClass="stats-container">
                <Label fx:id="trackedGenotypeLabel" text="Genotype: -" wrapText="true"/>
                <Label fx:id="trackedActiveGeneLabel" text="Active Gene: -"/>
                <Label fx:id="trackedEnergyLabel" text="Energy: -"/>
                <Label fx:id="trackedEatenLabel" text="Eaten: -"/>
                <Label fx:id="trackedChildrenLabel" text="Children: -"/>
                <Label fx:id="trackedDescendantsLabel" text="Descendants: -"/>
                <Label fx:id="trackedAgeLabel" text="Age: -"/>
                <Label fx:id="trackedDeathDayLabel" text="Death Day: -"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>
            <Label text="Simulation Log" styleClass="section-title"/>
            <ListView fx:id="logListView" VBox.vgrow="ALWAYS"
                      styleClass="log-list"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="mapContainer" styleClass="map-container">
            <Canvas fx:id="mapCanvas"/>
        </StackPane>
    </center>

    <right>
        <VBox spacing="10" styleClass="sidebar">
            <Label styleClass="section-title" text="Global Statistics"/>

            <VBox spacing="5" styleClass="stats-container">
                <Label fx:id="dayLabel" text="Day: 0" style="-fx-font-weight: bold;"/>
                <Label fx:id="animalCountLabel" text="Animals: 0"/>
                <Label fx:id="plantCountLabel" text="Plants: 0"/>
                <Label fx:id="emptyFieldsLabel" text="Empty Fields: 0"/>
                <Label fx:id="avgEnergyLabel" text="Avg Energy: 0"/>
                <Label fx:id="avgLifeSpanLabel" text="Avg LifeSpan: 0"/>
                <Label fx:id="childrenCountLabel" text="Avg Children: 0"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <Label text="Dominant Genotype:" styleClass="subtitle-label"/>
            <Label fx:id="mostCommonGenotypeLabel"
                   text="-"
                   wrapText="true"
                   styleClass="genotype-text"/>
        </VBox>
    </right>

    <bottom>
        <VBox spacing="5" styleClass="chart-section">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Chart Statistic:" styleClass="subtitle-label"/>
                <ChoiceBox fx:id="statChoiceBox" prefWidth="200.0"/>
            </HBox>

            <LineChart fx:id="statsChart" prefHeight="180.0" createSymbols="false" legendVisible="false">
                <xAxis>
                    <NumberAxis label="Days" side="BOTTOM"/>
                </xAxis>
                <yAxis>
                    <NumberAxis side="LEFT"/>
                </yAxis>
            </LineChart>
        </VBox>
    </bottom>

</BorderPane>