<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            minHeight="900.0" minWidth="1600.0"
            fx:controller="agh.ics.oop.simulationGUI.SimulationWindowPresenter">

    <top>
        <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10;">
            <Button text="Start" onAction="#onStartClicked"/>
            <Button text="Pause" onAction="#onPauseClicked"/>
        </HBox>
    </top>

    <center>
        <GridPane fx:id="mapGrid" alignment="CENTER" gridLinesVisible="true" style="-fx-background-color: #eee;"/>
    </center>

    <right>
        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ddd; -fx-min-width: 200;">
            <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Statistics"/>

            <Label text="Day:"/>
            <Label fx:id="dayLabel" text="0"/>

            <Label text="Animals:"/>
            <Label fx:id="animalCountLabel" text="0"/>

            <Label text="Plants:"/>
            <Label fx:id="plantCountLabel" text="0"/>

            <Label text="Empty Fields:"/>
            <Label fx:id="emptyFieldsLabel" text="0"/>

            <Label text="Avg Energy:"/>
            <Label fx:id="avgEnergyLabel" text="0"/>

            <Label text="Avg LifeSpan (Dead):"/>
            <Label fx:id="avgLifeSpanLabel" text="0"/>
        </VBox>
    </right>

</BorderPane>