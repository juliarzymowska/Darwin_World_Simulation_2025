<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>

<BorderPane minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="agh.ics.oop.simulationGUI.SimulationWindowPresenter">

    <top>
        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
            <Button onAction="#onStartClicked" text="Resume"/>
            <Button onAction="#onPauseClicked" text="Pause"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="mapContainer" style="-fx-background-color: #eeeeee; -fx-padding: 20;">
            <Canvas fx:id="mapCanvas" height="400.0" width="400.0"/>
        </StackPane>
    </center>

    <right>
        <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #ddd; -fx-min-width: 200;">
            <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Statistics"/>

            <Label fx:id="dayLabel" text="Day: 0"/>
            <Label fx:id="animalCountLabel" text="Animals: 0"/>
            <Label fx:id="plantCountLabel" text="Plants: 0"/>
            <Label fx:id="emptyFieldsLabel" text="Empty Fields: 0"/>
            <Label fx:id="avgEnergyLabel" text="Avg Energy: 0"/>
            <Label fx:id="avgLifeSpanLabel" text="Avg LifeSpan: 0"/>
            <Label fx:id="childrenCountLabel" text="Children Count: 0"/>
            <Label fx:id="mostCommonGenotypeLabel"
                   text="Most Common Genotype: N/A"
                   wrapText="true"
                   style="-fx-font-family: 'monospaced';"/>
        </VBox>
    </right>

    <bottom>
        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
            <LineChart fx:id="statsChart" prefHeight="150.0" HBox.hgrow="ALWAYS">
                <xAxis><NumberAxis side="BOTTOM" /></xAxis>
                <yAxis><NumberAxis side="LEFT" /></yAxis>
            </LineChart>
        </HBox>
    </bottom>

</BorderPane>